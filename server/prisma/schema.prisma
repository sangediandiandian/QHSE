generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RiskLevel {
  low
  medium
  high
  critical
}

enum DataScope {
  all
  assigned_areas
}

enum UserStatus {
  enabled
  disabled
}

model Organization {
  id        String         @id @default(uuid())
  parentId  String?
  code      String         @unique
  name      String
  type      String
  parent    Organization?  @relation("OrganizationTree", fields: [parentId], references: [id])
  children  Organization[] @relation("OrganizationTree")
  areas     Area[]
  users     User[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([parentId])
  @@map("organizations")
}

model Area {
  id             String               @id
  code           String               @unique
  name           String
  organizationId String
  organization   Organization         @relation(fields: [organizationId], references: [id])
  userAssignments UserAreaAssignment[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([organizationId])
  @@map("areas")
}

model User {
  id              String               @id @default(uuid())
  username        String               @unique
  passwordHash    String
  name            String
  title           String
  organizationId  String
  status          UserStatus           @default(enabled)
  tokenVersion    Int                  @default(1)
  organization    Organization         @relation(fields: [organizationId], references: [id])
  roles           UserRole[]
  areaAssignments UserAreaAssignment[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([organizationId, status])
  @@map("users")
}

model Role {
  id          String     @id @default(uuid())
  code        String     @unique
  name        String
  permissions String[]
  dataScope   DataScope
  users       UserRole[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("roles")
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model UserAreaAssignment {
  userId String
  areaId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  area   Area @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@id([userId, areaId])
  @@index([areaId])
  @@map("user_area_assignments")
}

model RiskUnit {
  id              String           @id @default(uuid())
  code            String           @unique
  name            String
  parentName      String
  areaId          String
  areaName        String
  ownerDepartment String
  owner           String
  medium          String
  accidentTypes   String[]
  staticLevel     RiskLevel
  currentLevel    RiskLevel
  controls        String[]
  linkedGds       Int              @default(0)
  linkedVoc       Int              @default(0)
  linkedMes       Int              @default(0)
  linkedPlans     Int              @default(0)
  dynamicFactors  Json
  version         Int              @default(1)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  assessments     RiskAssessment[]
  controlRecords  RiskControl[]
  hazards         Hazard[]

  @@index([areaId, currentLevel])
  @@map("risk_units")
}

model Hazard {
  id                String            @id @default(uuid())
  code              String            @unique
  title             String
  areaId            String
  areaName          String
  level             String
  source            String
  category          String
  ownerDepartment   String
  owner              String
  discoveredAt      DateTime
  deadline          DateTime
  status            String
  riskUnitId        String
  recurrenceCount   Int               @default(0)
  description       String
  measures          String[]
  supervised        Boolean           @default(false)
  acceptanceOpinion String?
  version           Int               @default(1)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  riskUnit          RiskUnit          @relation(fields: [riskUnitId], references: [id])
  evidence          HazardEvidence[]
  operations        HazardOperation[]

  @@index([areaId, status])
  @@index([riskUnitId, status])
  @@index([deadline, status])
  @@index([supervised, status])
  @@map("hazards")
}

model HazardEvidence {
  id         String   @id @default(uuid())
  hazardId   String
  name       String
  category   String
  uploaderId String
  uploader   String
  uploadedAt DateTime @default(now())
  note       String?
  hazard     Hazard   @relation(fields: [hazardId], references: [id], onDelete: Cascade)

  @@index([hazardId, uploadedAt])
  @@map("hazard_evidence")
}

model HazardOperation {
  id         String   @id @default(uuid())
  hazardId   String
  action     String
  operatorId String
  operator   String
  operatedAt DateTime @default(now())
  detail     String
  hazard     Hazard   @relation(fields: [hazardId], references: [id], onDelete: Cascade)

  @@index([hazardId, operatedAt])
  @@map("hazard_operations")
}

model WorkPermit {
  id                String                       @id @default(uuid())
  code              String                       @unique
  type              String
  areaId            String
  areaName          String
  workContent       String
  applicantId       String
  applicant         String
  guardian          String
  startAt           DateTime
  endAt             DateTime
  riskLevel         String
  status            String
  gasTest           String
  linkedGdsCodes    String[]
  safetyMeasures    String[]
  alertReason       String?
  workX             Float
  workY             Float
  version           Int                          @default(1)
  createdAt         DateTime                     @default(now())
  updatedAt         DateTime                     @updatedAt
  approvalSteps     WorkPermitApprovalStep[]
  siteConfirmations WorkPermitSiteConfirmation[]

  @@index([areaId, status])
  @@index([startAt, endAt])
  @@index([riskLevel, status])
  @@map("work_permits")
}

model WorkPermitApprovalStep {
  id           String     @id @default(uuid())
  workPermitId String
  sequence     Int
  role         String
  approverId   String?
  approver     String
  status       String
  signedAt     DateTime?
  signature    String?
  workPermit   WorkPermit @relation(fields: [workPermitId], references: [id], onDelete: Cascade)

  @@unique([workPermitId, sequence])
  @@index([workPermitId, status])
  @@map("work_permit_approval_steps")
}

model WorkPermitSiteConfirmation {
  id           String     @id @default(uuid())
  workPermitId String
  role         String
  confirmerId  String
  confirmer    String
  confirmedAt  DateTime   @default(now())
  workPermit   WorkPermit @relation(fields: [workPermitId], references: [id], onDelete: Cascade)

  @@unique([workPermitId, role])
  @@index([workPermitId, confirmedAt])
  @@map("work_permit_site_confirmations")
}

model WorkflowInstance {
  id            String         @id @default(uuid())
  businessType  String
  businessId    String
  title         String
  status        String
  createdById   String
  createdByName String
  version       Int            @default(1)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  steps         WorkflowStep[]

  @@index([businessType, businessId, status])
  @@index([createdById, status])
  @@map("workflow_instances")
}

model WorkflowStep {
  id               String           @id @default(uuid())
  workflowId       String
  sequence         Int
  name             String
  allowedRoleCodes String[]
  status           String
  actorId          String?
  actorName        String?
  opinion          String?
  actedAt          DateTime?
  workflow         WorkflowInstance @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, sequence])
  @@index([workflowId, status])
  @@map("workflow_steps")
}

model WarningRule {
  id                String               @id @default(uuid())
  code              String               @unique
  name              String
  source            String
  scenario          String
  level             RiskLevel
  scope             String
  condition         String
  duration          String
  notifyTargets     String[]
  description       String
  expression        Json
  rolloutPercentage Int                  @default(100)
  enabled           Boolean              @default(false)
  triggerCount      Int                  @default(0)
  lastTriggeredAt   DateTime?
  publishStatus     String
  version           Int                  @default(0)
  revision          Int                  @default(1)
  draft             Json?
  workflowId        String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  versions          WarningRuleVersion[]

  @@index([source, enabled])
  @@index([publishStatus, updatedAt])
  @@map("warning_rules")
}

model WarningRuleVersion {
  id                String      @id @default(uuid())
  warningRuleId     String
  version           Int
  name              String
  source            String
  scenario          String
  level             RiskLevel
  scope             String
  condition         String
  duration          String
  notifyTargets     String[]
  description       String
  expression        Json
  rolloutPercentage Int
  publishedAt       DateTime
  publisherId       String
  publisher         String
  warningRule       WarningRule @relation(fields: [warningRuleId], references: [id], onDelete: Cascade)

  @@unique([warningRuleId, version])
  @@index([warningRuleId, publishedAt])
  @@map("warning_rule_versions")
}

model WarningEvaluationState {
  id              String   @id @default(uuid())
  ruleId          String
  subjectId       String
  latestMetrics   Json
  metricTimes     Json
  conditionSince  DateTime?
  lastEvaluatedAt DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([ruleId, subjectId])
  @@index([lastEvaluatedAt])
  @@map("warning_evaluation_states")
}

model WarningSignal {
  id         String   @id @default(uuid())
  code       String   @unique
  ruleId     String
  ruleCode   String
  subjectId  String
  areaId     String?
  source     String
  level      RiskLevel
  title      String
  detail     String
  occurredAt DateTime
  status     String   @default("active")
  createdAt  DateTime @default(now())

  @@index([ruleId, subjectId, occurredAt])
  @@index([areaId, level, status])
  @@map("warning_signals")
}

model RiskAssessment {
  id          String    @id @default(uuid())
  riskUnitId  String
  assessorId  String
  method      String    @default("LEC")
  likelihood Float
  exposure    Float
  consequence Float
  score       Float
  level       RiskLevel
  assessor    String
  assessedAt  DateTime  @default(now())
  basis       String
  riskUnit    RiskUnit  @relation(fields: [riskUnitId], references: [id], onDelete: Cascade)

  @@index([riskUnitId, assessedAt])
  @@map("risk_assessments")
}

model RiskControl {
  id         String   @id
  riskUnitId String
  content    String
  owner      String
  status     String
  updatedAt  DateTime @default(now())
  riskUnit   RiskUnit @relation(fields: [riskUnitId], references: [id], onDelete: Cascade)

  @@index([riskUnitId])
  @@map("risk_controls")
}

model AuditLog {
  id           String   @id @default(uuid())
  requestId    String
  actorId      String?
  actorName    String?
  action       String
  resourceType String
  resourceId   String?
  result       String
  method       String
  path         String
  ip           String?
  durationMs   Int
  detail       Json?
  createdAt    DateTime @default(now())

  @@index([resourceType, resourceId, createdAt])
  @@index([actorId, createdAt])
  @@index([requestId])
  @@map("audit_logs")
}
